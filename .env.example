APP_NAME=yuanmian-ai-agent
HOST=0.0.0.0
PORT=8291
DEBUG=true

# OpenAI-compatible 主模型（如 DeepSeek）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL_NAME=deepseek-chat
OPENAI_MAX_OUTPUT_TOKENS=800

# OpenAI-compatible 小模型（如 DashScope Qwen）
OPENAI_SMALL_API_KEY=
OPENAI_SMALL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_SMALL_MODEL_NAME=qwen-turbo
OPENAI_SMALL_MAX_OUTPUT_TOKENS=800
